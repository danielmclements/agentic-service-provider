DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agentic_msp"
PORT=4000
NODE_ENV=development
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_TASK_QUEUE=agentic-msp
TEMPORAL_NAMESPACE=default
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AUTH0_DOMAIN=example.us.auth0.com
AUTH0_AUDIENCE=https://agentic-service-provider/api
AUTH0_ISSUER=https://example.us.auth0.com/
AUTH0_CLIENT_ID=operator-console
AUTH0_CLIENT_SECRET=
AUTH0_MANAGEMENT_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_SECRET=
AUTH0_MANAGEMENT_AUDIENCE=
AUTH0_PROVISIONING_CONNECTION=
AUTH0_CALLBACK_URL=http://localhost:4000/auth/callback
AUTH0_LOGOUT_URL=http://localhost:4000/operator
AUTH0_DEFAULT_ORGANIZATION=org_replace_me
AUTH0_DEFAULT_CONNECTION=
AUTH0_JWT_ALGORITHMS=HS256
AUTH0_JWKS_URL=
AUTH0_JWT_SECRET=dev-auth0-secret
AUTH0_JWT_PUBLIC_KEY=
AUTH0_PERMISSIONS_CLAIM=permissions
AUTH0_ROLES_CLAIM=https://agentic-service-provider/roles
AUTH0_TENANT_CLAIM=https://agentic-service-provider/tenant_id
AUTH0_MFA_FRESHNESS_SECONDS=300
TRUST_PROXY=loopback, linklocal, uniquelocal
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
SESSION_COOKIE_NAME=asp_operator_session
AUTH_STATE_COOKIE_NAME=asp_auth_state
AUTH_CODE_VERIFIER_COOKIE_NAME=asp_auth_code_verifier
AUTH_NONCE_COOKIE_NAME=asp_auth_nonce
AUTH_ORGANIZATION_COOKIE_NAME=asp_auth_organization
