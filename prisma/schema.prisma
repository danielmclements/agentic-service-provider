generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IdentityProvider {
  MOCK
  M365
}

enum TicketStatus {
  RECEIVED
  TRIAGED
  WAITING_VERIFICATION
  WAITING_APPROVAL
  EXECUTING
  RESOLVED
  REJECTED
  BLOCKED
}

enum ActionType {
  RESET_PASSWORD
  UNLOCK_ACCOUNT
  ADD_TO_GROUP
  DISABLE_MFA
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum PolicyDecision {
  AUTO_EXECUTE
  REQUIRES_APPROVAL
  BLOCK
}

enum ActionStatus {
  PENDING
  WAITING_VERIFICATION
  WAITING_APPROVAL
  APPROVED
  REJECTED
  BLOCKED
  EXECUTING
  SUCCEEDED
  FAILED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExecutionRunStatus {
  PENDING
  RUNNING
  WAITING_VERIFICATION
  COMPLETED
  FAILED
  WAITING_APPROVAL
}

enum TenantRole {
  TENANT_ADMIN
  TENANT_OPERATOR
  TENANT_END_USER
}

enum AuthConnectionStrategy {
  AUTH0_DATABASE
  OIDC
  SAML
}

enum VerificationMethod {
  PUSH
  WEBAUTHN
  SMS
  MANUAL_REVIEW
}

enum VerificationStatus {
  PENDING
  VERIFIED
  FAILED
  EXPIRED
  BYPASSED
}

enum UserProvisioningStatus {
  LOCAL_ONLY
  PROVISIONED
  INVITED
  ERROR
}

model Tenant {
  id               String           @id @default(cuid())
  slug             String           @unique
  name             String
  identityProvider IdentityProvider
  createdAt        DateTime         @default(now())
  policy           TenantPolicy?
  tickets          Ticket[]
  auditLogs        AuditLog[]
  memberships      TenantMembership[]
  authConnections  TenantAuthConnection[]
  operatorSessions OperatorSession[]
  connectorConfigs TenantConnectorConfig[]
}

model User {
  id                String                 @id @default(cuid())
  auth0UserId       String                 @unique
  email             String?
  displayName       String?
  globalRoles       Json
  active            Boolean                @default(true)
  provisioningStatus UserProvisioningStatus @default(LOCAL_ONLY)
  invitedAt         DateTime?
  lastAuth0SyncAt   DateTime?
  lastAuth0SyncError String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  memberships       TenantMembership[]
  sessions          OperatorSession[]
}

model TenantPolicy {
  id             String  @id @default(cuid())
  tenantId       String  @unique
  allowedActions Json
  approvalRules  Json
  modelSettings  Json
  verificationSettings Json?
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Ticket {
  id                String         @id @default(cuid())
  tenantId          String
  userEmail         String
  message           String
  normalizedMessage String
  metadata          Json?
  externalTicketRef String?
  idempotencyKey    String?
  status            TicketStatus   @default(RECEIVED)
  triageCategory    String?
  triageIntent      String?
  triageConfidence  Float?
  triageAction      ActionType?
  triageRationale   String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actionRequests    ActionRequest[]
  approvals         Approval[]
  auditLogs         AuditLog[]
  executionRuns     ExecutionRun[]

  @@unique([tenantId, idempotencyKey])
}

model ActionRequest {
  id             String         @id @default(cuid())
  ticketId       String
  actionType     ActionType
  riskLevel      RiskLevel
  policyDecision PolicyDecision
  status         ActionStatus   @default(PENDING)
  inputPayload   Json
  outputPayload  Json?
  errorMessage   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  ticket         Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  approval       Approval?
  auditLogs      AuditLog[]
  verificationChallenge VerificationChallenge?
}

model Approval {
  id               String         @id @default(cuid())
  ticketId         String
  actionRequestId  String         @unique
  status           ApprovalStatus @default(PENDING)
  reviewerIdentity String?
  reviewerComment  String?
  decidedAt        DateTime?
  createdAt        DateTime       @default(now())
  ticket           Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actionRequest    ActionRequest  @relation(fields: [actionRequestId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id              String         @id @default(cuid())
  tenantId        String
  ticketId        String?
  actionRequestId String?
  eventType       String
  actor           String
  actorSubject    String?
  actorOrgId      String?
  actorSessionId  String?
  actorDisplayName String?
  approvedBy      String?
  payload         Json
  createdAt       DateTime       @default(now())
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticket          Ticket?        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actionRequest   ActionRequest? @relation(fields: [actionRequestId], references: [id], onDelete: Cascade)
}

model ExecutionRun {
  id          String             @id @default(cuid())
  ticketId    String
  workflowId  String             @unique
  status      ExecutionRunStatus @default(PENDING)
  currentStep String?
  lastError   String?
  startedAt   DateTime           @default(now())
  completedAt DateTime?
  ticket      Ticket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model TenantMembership {
  id            String       @id @default(cuid())
  tenantId      String
  userId        String
  auth0OrgId    String
  email         String?
  displayName   String?
  role          TenantRole
  permissions   Json
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions      OperatorSession[]

  @@unique([tenantId, userId])
  @@index([tenantId, auth0OrgId])
}

model TenantAuthConnection {
  id                  String                 @id @default(cuid())
  tenantId            String
  auth0OrganizationId String                 @unique
  auth0OrganizationName String?
  displayName         String
  strategy            AuthConnectionStrategy
  connectionName      String
  issuer              String?
  clientId            String?
  metadata            Json?
  isDefault           Boolean                @default(false)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  tenant              Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isDefault])
  @@index([auth0OrganizationName])
}

model OperatorSession {
  id                 String           @id @default(cuid())
  tenantId           String
  membershipId       String?
  userId             String
  auth0OrganizationId String
  sessionId          String           @unique
  email              String?
  displayName        String?
  roles              Json
  permissions        Json
  authTime           DateTime
  amr                Json
  lastSeenAt         DateTime         @default(now())
  revokedAt          DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membership         TenantMembership? @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
}

model VerificationChallenge {
  id               String             @id @default(cuid())
  actionRequestId  String             @unique
  method           VerificationMethod
  status           VerificationStatus @default(PENDING)
  targetReference  String
  evidencePayload  Json?
  issuedAt         DateTime           @default(now())
  expiresAt        DateTime
  completedAt      DateTime?
  attemptCount     Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  actionRequest    ActionRequest      @relation(fields: [actionRequestId], references: [id], onDelete: Cascade)
}

model TenantConnectorConfig {
  id                   String   @id @default(cuid())
  tenantId             String
  provider             IdentityProvider
  entraTenantId        String?
  clientId             String?
  clientSecretVaultRef String?
  clientCertVaultRef   String?
  allowedGraphScopes   Json
  allowedTargetGroups  Json
  metadata             Json?
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
}
