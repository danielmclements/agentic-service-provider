NODE_ENV=production
PORT=4000
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_TASK_QUEUE=agentic-msp
TEMPORAL_NAMESPACE=default

OPS_DOMAIN=ops.danielclements.me
TEMPORAL_DOMAIN=temporal.danielclements.me
CADDY_EMAIL=daniel@danielclements.me
TEMPORAL_ALLOWED_CIDRS=203.0.113.10/32
TEMPORAL_BASICAUTH_USERNAME=temporal-admin
TEMPORAL_BASICAUTH_PASSWORD_HASH=PASTE_CADDY_BCRYPT_HASH_HERE

AUTH0_DOMAIN=replace-me.us.auth0.com
AUTH0_AUDIENCE=https://agentic-service-provider/api
AUTH0_ISSUER=https://replace-me.us.auth0.com/
AUTH0_CLIENT_ID=replace-me
AUTH0_CALLBACK_URL=https://ops.danielclements.me/auth/callback
AUTH0_LOGOUT_URL=https://ops.danielclements.me/operator
AUTH0_DEFAULT_ORGANIZATION=org_replace_me
AUTH0_DEFAULT_CONNECTION=
AUTH0_JWT_ALGORITHMS=RS256
AUTH0_JWKS_URL=https://replace-me.us.auth0.com/.well-known/jwks.json
AUTH0_PERMISSIONS_CLAIM=permissions
AUTH0_ROLES_CLAIM=https://agentic-service-provider/roles
AUTH0_TENANT_CLAIM=https://agentic-service-provider/tenant_id
AUTH0_MFA_FRESHNESS_SECONDS=300

TRUST_PROXY=loopback, linklocal, uniquelocal
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

SESSION_COOKIE_NAME=asp_operator_session
AUTH_STATE_COOKIE_NAME=asp_auth_state
AUTH_CODE_VERIFIER_COOKIE_NAME=asp_auth_code_verifier
AUTH_NONCE_COOKIE_NAME=asp_auth_nonce

POSTGRES_DB=agentic_msp
POSTGRES_USER=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
BACKUP_INTERVAL_SECONDS=21600
BACKUP_RETENTION_DAYS=14
